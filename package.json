{
  "name": "whizmob",
  "version": "0.1.3",
  "description": "Discover, visualize, and port your AI agent systems across Claude Code, Cursor, and Codex",
  "type": "module",
  "bin": {
    "whizmob": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "scan": "node dist/index.js scan",
    "start": "node dist/index.js",
    "dashboard": "cd dashboard && npm run dev",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "keywords": [
    "claude-code",
    "cursor",
    "codex",
    "agents",
    "ai-agents",
    "inventory",
    "cli",
    "portability",
    "mobs",
    "inspector",
    "graph"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bigheavyio/whizmob"
  },
  "homepage": "https://whizmob.dev",
  "author": "George Quraishi <george@bigheavy.fun>",
  "license": "MIT",
  "files": [
    "dist/",
    "exports/"
  ],
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
