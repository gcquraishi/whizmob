{
  "name": "ronin",
  "version": "0.2.0",
  "description": "Agent inventory and management tool for AI-assisted development",
  "type": "module",
  "bin": {
    "ronin": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "scan": "node dist/index.js scan",
    "start": "node dist/index.js",
