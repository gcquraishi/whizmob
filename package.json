{
  "name": "ronin",
  "version": "0.2.0",
  "description": "Agent inventory and management tool for AI-assisted development",
  "type": "module",
  "bin": {
    "ronin": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "scan": "node dist/index.js scan",
    "start": "node dist/index.js",
    "dashboard": "cd dashboard && npm run dev"
  },
  "keywords": [
    "claude-code",
    "agents",
    "inventory",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
